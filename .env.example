# Database
DATABASE_URL=postgresql+asyncpg://postgres:secret@postgres:5432/2fa_db
DATABASE_URL_SYNC=postgresql://postgres:secret@postgres:5432/2fa_db

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
SECRET_KEY=your-super-secret-key-change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Firebase Cloud Messaging
FCM_CREDENTIALS_PATH=/app/firebase-credentials.json
FCM_PROJECT_ID=your-firebase-project-id

# Admin Panel
ADMIN_USERNAME=admin
# Хеш пароля админ-панели (Argon2). Сгенерировать: python -c "from passlib.context import CryptContext; print(CryptContext(schemes=['argon2']).hash('your_password'))"
ADMIN_PASSWORD_HASH=argon2_hash_here

# Application
APP_NAME=2FA Service
DEBUG=False